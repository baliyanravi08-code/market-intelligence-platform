<script>
// ─────────────────────────────────────────────────
//  DATA GENERATION
// ─────────────────────────────────────────────────
function genCandles(n=120, base=490, vol=18, drift=-0.0002) {
  const c = [];
  let p = base;
  let date = new Date('2025-08-01');
  for(let i=0;i<n;i++){
    const r = ()=> Math.random()-0.5;
    const chg = p*(drift + r()*0.025);
    const o = p;
    const c2 = p + chg;
    const h = Math.max(o,c2)+Math.abs(r()*vol*0.5);
    const l = Math.min(o,c2)-Math.abs(r()*vol*0.5);
    const v = 1e6 + Math.abs(r())*3e6;
    c.push({
      date: new Date(date),
      o: +o.toFixed(2), h: +h.toFixed(2),
      l: +l.toFixed(2), c: +c2.toFixed(2),
      v: Math.round(v)
    });
    p = c2;
    // skip weekends
    date.setDate(date.getDate()+1);
    if(date.getDay()===6) date.setDate(date.getDate()+2);
    if(date.getDay()===0) date.setDate(date.getDate()+1);
  }
  return c;
}

// Force last candle to match VBL data
let CANDLES = genCandles(120,510,18,-0.003);
CANDLES[CANDLES.length-1] = {
  ...CANDLES[CANDLES.length-1],
  o:496.91, h:502.29, l:484.41, c:493.70, v:1840000,
  date: new Date('2026-04-27')
};

// ─── Indicators ─────────────────────────────────
function sma(data,n){ return data.map((_,i)=>i<n-1?null:data.slice(i-n+1,i+1).reduce((a,b)=>a+b,0)/n); }
function ema(data,n){
  const k=2/(n+1), out=[];
  data.forEach((v,i)=>{ out.push(i===0?v: out[i-1]+(v-out[i-1])*k); });
  return out;
}
function bb(data,n=20,mult=2){
  return data.map((_,i)=>{
    if(i<n-1) return {mid:null,upper:null,lower:null};
    const sl=data.slice(i-n+1,i+1);
    const m=sl.reduce((a,b)=>a+b,0)/n;
    const sd=Math.sqrt(sl.map(x=>(x-m)**2).reduce((a,b)=>a+b,0)/n);
    return{mid:m,upper:m+mult*sd,lower:m-mult*sd};
  });
}
function macd(data,fast=12,slow=26,sig=9){
  const ef=ema(data,fast),es=ema(data,slow);
  const line=ef.map((v,i)=>v-es[i]);
  const signal=ema(line,sig);
  return{line,signal,hist:line.map((v,i)=>v-signal[i])};
}
function rsi(data,n=14){
  const out=[];
  for(let i=0;i<data.length;i++){
    if(i<n){out.push(null);continue;}
    const ch=data.slice(i-n+1,i+1).map((v,j,a)=>j===0?0:v-a[j-1]);
    const g=ch.filter(x=>x>0).reduce((a,b)=>a+b,0)/n;
    const l=Math.abs(ch.filter(x=>x<0).reduce((a,b)=>a+b,0))/n;
    out.push(l===0?100:100-100/(1+g/l));
  }
  return out;
}
function stoch(highs,lows,closes,n=14){
  return closes.map((_,i)=>{
    if(i<n-1) return{k:null,d:null};
    const sl=i-n+1;
    const lls=Math.min(...lows.slice(sl,i+1));
    const hhs=Math.max(...highs.slice(sl,i+1));
    const k=hhs===lls?50:(closes[i]-lls)/(hhs-lls)*100;
    return{k};
  });
}
function supertrend(highs,lows,closes,period=7,mult=3){
  const atr=closes.map((_,i)=>{
    if(i===0) return highs[0]-lows[0];
    return Math.max(highs[i]-lows[i],Math.abs(highs[i]-closes[i-1]),Math.abs(lows[i]-closes[i-1]));
  });
  // simple sma atr
  const atrSma=sma(atr,period);
  return closes.map((c,i)=>{
    if(atrSma[i]===null) return{trend:'up',val:null};
    const ub=(highs[i]+lows[i])/2+mult*atrSma[i];
    const lb=(highs[i]+lows[i])/2-mult*atrSma[i];
    const trend=c<lb?'down':'up';
    return{trend,val:trend==='up'?lb:ub};
  });
}
function vwap(highs,lows,closes,vols){
  let cumPV=0,cumV=0;
  return closes.map((_,i)=>{
    const tp=(highs[i]+lows[i]+closes[i])/3;
    cumPV+=tp*vols[i]; cumV+=vols[i];
    return cumPV/cumV;
  });
}

const closes = CANDLES.map(c=>c.c);
const highs  = CANDLES.map(c=>c.h);
const lows   = CANDLES.map(c=>c.l);
const vols   = CANDLES.map(c=>c.v);

const INDS = {
  ma5:  sma(closes,5),
  ma9:  sma(closes,9),
  ma21: sma(closes,21),
  ma50: sma(closes,50),
  ma200:sma(closes,200),
  bb:   bb(closes,20,2),
  macd: macd(closes),
  rsi:  rsi(closes),
  stoch:stoch(highs,lows,closes),
  st:   supertrend(highs,lows,closes),
  vwap: vwap(highs,lows,closes,vols),
};

// ─────────────────────────────────────────────────
//  STATE
// ─────────────────────────────────────────────────
const state = {
  zoom: 1.0, panX: 0,
  fsZoom: 1.0,
  activePanel: 'macd',
  inds: {ma5:true,ma9:true,ma21:true,ma50:true,ma200:true,st:true,vwap:true,bb:true},
  dragging:false, dragStart:0, panStart:0,
};

// Zoom: visible candle count
function visibleCount() { return Math.round(80/state.zoom); }
function startIdx()     { const vc=visibleCount(); return Math.max(0,Math.min(CANDLES.length-vc, Math.round(state.panX))); }

// ─────────────────────────────────────────────────
//  CANVAS HELPERS
// ─────────────────────────────────────────────────
function setupCanvas(canvas, wrap) {
  const dpr = window.devicePixelRatio||1;
  const w = wrap.clientWidth, h = wrap.clientHeight;
  canvas.width  = w*dpr; canvas.height = h*dpr;
  canvas.style.width=w+'px'; canvas.style.height=h+'px';
  const ctx = canvas.getContext('2d');
  ctx.scale(dpr,dpr);
  return {ctx,w,h};
}

// ─────────────────────────────────────────────────
//  DRAW MAIN CHART
// ─────────────────────────────────────────────────
function drawMain(canvas, wrap, zoom, panX) {
  const {ctx,w,h} = setupCanvas(canvas,wrap);
  ctx.clearRect(0,0,w,h);

  const vc  = Math.round(80/zoom);
  const si  = Math.max(0,Math.min(CANDLES.length-vc, Math.round(panX)));
  const ei  = Math.min(CANDLES.length, si+vc);
  const vis = CANDLES.slice(si,ei);
  const indSlice = k => INDS[k] ? INDS[k].slice(si,ei) : [];

  // price range
  let mn=Infinity,mx=-Infinity;
  vis.forEach(c=>{ mn=Math.min(mn,c.l); mx=Math.max(mx,c.h); });
  // include BB
  if(state.inds.bb){ indSlice('bb').forEach(b=>{ if(b.upper){mx=Math.max(mx,b.upper);mn=Math.min(mn,b.lower);} }); }
  const pad=( mx-mn)*0.08; mn-=pad; mx+=pad;

  const cw = w/vc;
  const py=(v)=>h-(v-mn)/(mx-mn)*h;

  // Grid
  ctx.strokeStyle='#1e3048'; ctx.lineWidth=0.5;
  const gridN=6;
  for(let i=0;i<=gridN;i++){
    const y=h*i/gridN;
    ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(w,y); ctx.stroke();
    const val=(mx-(mx-mn)*i/gridN).toFixed(1);
    ctx.fillStyle='#3d5a72'; ctx.font='9px JetBrains Mono';
    ctx.fillText('₹'+val, 4, y-3);
  }
  // vertical grid
  const step=Math.max(1,Math.floor(vc/8));
  for(let i=0;i<vc;i+=step){
    const x=(i+0.5)*cw;
    ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,h); ctx.stroke();
    if(i<vis.length){
      const d=vis[i].date;
      const label=d.toLocaleDateString('en-IN',{day:'2-digit',month:'short'});
      ctx.fillStyle='#3d5a72'; ctx.font='9px JetBrains Mono';
      ctx.fillText(label,x-14,h-4);
    }
  }

  // BB
  if(state.inds.bb){
    const bs=indSlice('bb');
    ctx.beginPath();
    bs.forEach((b,i)=>{ if(b.upper==null)return; const x=(i+0.5)*cw; if(i===0||!bs[i-1]?.upper)ctx.moveTo(x,py(b.upper));else ctx.lineTo(x,py(b.upper)); });
    ctx.strokeStyle='rgba(96,125,139,.5)'; ctx.lineWidth=1; ctx.setLineDash([4,3]); ctx.stroke();
    ctx.beginPath();
    bs.forEach((b,i)=>{ if(b.lower==null)return; const x=(i+0.5)*cw; if(i===0||!bs[i-1]?.lower)ctx.moveTo(x,py(b.lower));else ctx.lineTo(x,py(b.lower)); });
    ctx.stroke();
    ctx.setLineDash([]);
    // fill
    ctx.beginPath();
    bs.forEach((b,i)=>{ if(b.upper==null)return; const x=(i+0.5)*cw; if(i===0||!bs[i-1]?.upper)ctx.moveTo(x,py(b.upper));else ctx.lineTo(x,py(b.upper)); });
    bs.slice().reverse().forEach((b,i)=>{ if(b.lower==null)return; const x=(vc-1-i+0.5)*cw; ctx.lineTo(x,py(b.lower)); });
    ctx.closePath();
    ctx.fillStyle='rgba(96,125,139,.04)'; ctx.fill();
  }

  // MA lines
  const maColors={ma5:'#e91e63',ma9:'#ff9800',ma21:'#2196f3',ma50:'#4caf50',ma200:'#9c27b0'};
  Object.entries(maColors).forEach(([k,col])=>{
    if(!state.inds[k]) return;
    const sl=indSlice(k); let started=false;
    ctx.beginPath(); ctx.strokeStyle=col; ctx.lineWidth=1.2; ctx.setLineDash([]);
    sl.forEach((v,i)=>{ if(v==null)return; const x=(i+0.5)*cw; if(!started){ctx.moveTo(x,py(v));started=true;}else ctx.lineTo(x,py(v)); });
    ctx.stroke();
  });

  // VWAP
  if(state.inds.vwap){
    const vw=indSlice('vwap'); let started=false;
    ctx.beginPath(); ctx.strokeStyle='#ffeb3b'; ctx.lineWidth=1.3; ctx.setLineDash([5,3]);
    vw.forEach((v,i)=>{ if(v==null)return; const x=(i+0.5)*cw; if(!started){ctx.moveTo(x,py(v));started=true;}else ctx.lineTo(x,py(v)); });
    ctx.stroke(); ctx.setLineDash([]);
  }

  // SuperTrend
  if(state.inds.st){
    const sts=indSlice('st');
    sts.forEach((s,i)=>{
      if(s.val==null) return;
      const x=(i+0.5)*cw;
      const y=py(s.val);
      ctx.beginPath();
      ctx.arc(x,y,1.5,0,Math.PI*2);
      ctx.fillStyle=s.trend==='up'?'#00e676':'#ef5350';
      ctx.fill();
    });
  }

  // Candles
  vis.forEach((c,i)=>{
    const x=(i+0.5)*cw;
    const bull=c.c>=c.o;
    const col=bull?'#26a69a':'#ef5350';
    const bodyW=Math.max(cw*0.55,2);

    // wick
    ctx.strokeStyle=col; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(x,py(c.h)); ctx.lineTo(x,py(c.l)); ctx.stroke();

    // body
    const by=py(Math.max(c.o,c.c));
    const bh=Math.max(Math.abs(py(c.o)-py(c.c)),1);
    ctx.fillStyle=bull?'rgba(38,166,154,.85)':'rgba(239,83,80,.85)';
    ctx.fillRect(x-bodyW/2,by,bodyW,bh);
    ctx.strokeStyle=bull?'#26a69a':'#ef5350';
    ctx.strokeRect(x-bodyW/2,by,bodyW,bh);
  });

  // Last price line
  const lp=CANDLES[CANDLES.length-1].c;
  const ly=py(lp);
  if(ly>0&&ly<h){
    ctx.setLineDash([4,4]); ctx.strokeStyle='rgba(0,229,255,.4)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(0,ly); ctx.lineTo(w,ly); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle='rgba(0,229,255,.9)'; ctx.font='bold 10px JetBrains Mono';
    ctx.fillText('₹'+lp.toFixed(2), w-62, ly-3);
    ctx.fillStyle='rgba(0,37,54,.9)';
    const tw=ctx.measureText('₹'+lp.toFixed(2)).width;
    ctx.fillStyle='#00e5ff'; ctx.fillText('₹'+lp.toFixed(2), w-62, ly-3);
  }

  // Return for crosshair
  return {mn,mx,si,vc,w,h,cw};
}

// ─────────────────────────────────────────────────
//  DRAW SUB PANEL 1 (MACD / RSI / VOL)
// ─────────────────────────────────────────────────
function drawSub1(canvas, wrap) {
  const {ctx,w,h} = setupCanvas(canvas, wrap);
  ctx.clearRect(0,0,w,h);
  const vc=Math.round(80/state.zoom);
  const si=startIdx();
  const ei=Math.min(CANDLES.length,si+vc);
  const cw=w/vc;

  if(state.activePanel==='macd'){
    const {line,signal,hist}=INDS.macd;
    const sl=line.slice(si,ei),ss=signal.slice(si,ei),sh=hist.slice(si,ei);
    let mn=Infinity,mx=-Infinity;
    sh.forEach(v=>{ if(v!=null){mn=Math.min(mn,v);mx=Math.max(mx,v);} });
    sl.forEach(v=>{ if(v!=null){mn=Math.min(mn,v);mx=Math.max(mx,v);} });
    const pad=(mx-mn)*0.1; mn-=pad; mx+=pad;
    const py=(v)=>h-(v-mn)/(mx-mn)*h;
    const zero=py(0);
    ctx.strokeStyle='#1e3048'; ctx.lineWidth=0.5;
    ctx.beginPath(); ctx.moveTo(0,zero); ctx.lineTo(w,zero); ctx.stroke();
    // histogram
    sh.forEach((v,i)=>{ if(v==null)return; const x=(i+0.5)*cw, y=py(v); ctx.fillStyle=v>=0?'rgba(0,230,118,.5)':'rgba(239,83,80,.5)'; ctx.fillRect(x-cw*0.35,Math.min(y,zero),cw*0.7,Math.abs(y-zero)); });
    // lines
    const drawLine=(arr,col,lw=1)=>{ let s=false; ctx.beginPath(); ctx.strokeStyle=col; ctx.lineWidth=lw; arr.forEach((v,i)=>{ if(v==null)return; const x=(i+0.5)*cw; s?ctx.lineTo(x,py(v)):ctx.moveTo(x,py(v)); s=true; }); ctx.stroke(); };
    drawLine(sl,'#2196f3',1.2); drawLine(ss,'#ff9800',1);
    ctx.fillStyle='#3d5a72'; ctx.font='9px JetBrains Mono';
    ctx.fillText(`MACD: ${sl[sl.length-1]?.toFixed(2)??'—'}  Signal: ${ss[ss.length-1]?.toFixed(2)??'—'}  Hist: ${sh[sh.length-1]?.toFixed(2)??'—'}`, 6, 10);
  } else if(state.activePanel==='rsi'){
    const rs=INDS.rsi.slice(si,ei), st=INDS.stoch.slice(si,ei);
    const py=(v)=>h-(v/100)*h;
    [30,50,70].forEach(v=>{ ctx.strokeStyle='#1e3048'; ctx.lineWidth=0.5; ctx.setLineDash(v===50?[]:[]); ctx.beginPath(); ctx.moveTo(0,py(v)); ctx.lineTo(w,py(v)); ctx.stroke(); });
    ctx.fillStyle='rgba(0,229,255,.04)'; ctx.fillRect(0,py(70),w,py(30)-py(70));
    const drawLine=(arr,col,lw=1)=>{ let s=false; ctx.beginPath(); ctx.strokeStyle=col; ctx.lineWidth=lw; arr.forEach((v,i)=>{ if(v==null)return; const x=(i+0.5)*cw; s?ctx.lineTo(x,py(v)):ctx.moveTo(x,py(v)); s=true; }); ctx.stroke(); };
    drawLine(rs,'#e91e63',1.3);
    drawLine(st.map(s=>s.k),'#ff9800',1);
    const lastRsi=rs[rs.length-1];
    ctx.fillStyle='#3d5a72'; ctx.font='9px JetBrains Mono';
    ctx.fillText(`RSI(14): ${lastRsi?.toFixed(1)??'—'}`, 6, 10);
  } else {
    // Volume
    const vs=CANDLES.slice(si,ei).map(c=>c.v);
    const mv=Math.max(...vs);
    vs.forEach((v,i)=>{ const c=CANDLES[si+i]; const x=(i+0.5)*cw, bh=(v/mv)*(h-4); ctx.fillStyle=c.c>=c.o?'rgba(38,166,154,.6)':'rgba(239,83,80,.6)'; ctx.fillRect(x-cw*0.4,h-bh,cw*0.8,bh); });
    ctx.fillStyle='#3d5a72'; ctx.font='9px JetBrains Mono'; ctx.fillText('VOLUME',6,10);
  }
}

// ─────────────────────────────────────────────────
//  DRAW SUB PANEL 2 (Volume always)
// ─────────────────────────────────────────────────
function drawSub2(canvas, wrap) {
  const {ctx,w,h} = setupCanvas(canvas, wrap);
  ctx.clearRect(0,0,w,h);
  const vc=Math.round(80/state.zoom);
  const si=startIdx();
  const ei=Math.min(CANDLES.length,si+vc);
  const cw=w/vc;
  const vis=CANDLES.slice(si,ei);
  const mv=Math.max(...vis.map(c=>c.v));
  vis.forEach((c,i)=>{
    const x=(i+0.5)*cw, bh=(c.v/mv)*(h-6);
    ctx.fillStyle=c.c>=c.o?'rgba(38,166,154,.5)':'rgba(239,83,80,.5)';
    ctx.fillRect(x-cw*0.4,h-bh,cw*0.8,bh);
  });
  ctx.fillStyle='#3d5a72'; ctx.font='9px JetBrains Mono'; ctx.fillText('VOLUME · OBV',6,10);
}

// ─────────────────────────────────────────────────
//  RENDER ALL
// ─────────────────────────────────────────────────
let lastInfo=null;
function renderAll(){
  const wrap=document.getElementById('chartWrap');
  const canvas=document.getElementById('mainChart');
  lastInfo=drawMain(canvas,wrap,state.zoom,state.panX);
  drawSub1(document.getElementById('subChart1'),document.getElementById('subPanel1'));
  drawSub2(document.getElementById('subChart2'),document.getElementById('subPanel2'));
  document.getElementById('zoomLbl').textContent=Math.round(state.zoom*100)+'%';
}
function renderFS(){
  const wrap=document.getElementById('fsChartWrap');
  const canvas=document.getElementById('fsChart');
  drawMain(canvas,wrap,state.fsZoom,state.panX);
  document.getElementById('fsZoomLbl').textContent=Math.round(state.fsZoom*100)+'%';
}

// ─────────────────────────────────────────────────
//  ZOOM & PAN
// ─────────────────────────────────────────────────
function zoomChart(dir){
  state.zoom=Math.max(0.3,Math.min(8,state.zoom+dir*0.15));
  renderAll();
}
function zoomReset(){ state.zoom=1; state.panX=CANDLES.length-80; renderAll(); }
function zoomFS(dir){
  state.fsZoom=Math.max(0.3,Math.min(8,state.fsZoom+dir*0.15));
  renderFS();
}

// Mouse wheel zoom
document.getElementById('chartWrap').addEventListener('wheel',e=>{
  e.preventDefault();
  const dir = e.deltaY<0?1:-1;
  state.zoom=Math.max(0.3,Math.min(8,state.zoom+dir*0.12));
  renderAll();
},{passive:false});

// Pinch zoom
let lastPinch=0;
document.getElementById('chartWrap').addEventListener('touchmove',e=>{
  if(e.touches.length===2){
    const d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
    if(lastPinch){ const dd=d-lastPinch; state.zoom=Math.max(0.3,Math.min(8,state.zoom+dd*0.005)); renderAll(); }
    lastPinch=d;
  }
},{passive:true});
document.getElementById('chartWrap').addEventListener('touchend',()=>{ lastPinch=0; });

// Pan (drag)
const cw=document.getElementById('chartWrap');
cw.addEventListener('mousedown',e=>{ state.dragging=true; state.dragStart=e.clientX; state.panStart=state.panX; });
window.addEventListener('mousemove',e=>{
  if(!state.dragging) return;
  const dx=e.clientX-state.dragStart;
  const vc=Math.round(80/state.zoom);
  const canvasPx=cw.clientWidth;
  state.panX=state.panStart-dx*(vc/canvasPx);
  state.panX=Math.max(0,Math.min(CANDLES.length-vc,state.panX));
  renderAll();
});
window.addEventListener('mouseup',()=>{ state.dragging=false; });

// Initialize pan to show last candles
state.panX = Math.max(0, CANDLES.length - 80);

// ─────────────────────────────────────────────────
//  CROSSHAIR
// ─────────────────────────────────────────────────
const tt=document.getElementById('tooltip');
cw.addEventListener('mousemove',e=>{
  if(state.dragging||!lastInfo) return;
  const rect=cw.getBoundingClientRect();
  const mx=e.clientX-rect.left;
  const {cw:cwidth,vc,si}=lastInfo;
  const idx=Math.floor(mx/cwidth);
  const absIdx=si+idx;
  if(absIdx<0||absIdx>=CANDLES.length) return;
  const c=CANDLES[absIdx];
  // crosshair info bar
  document.getElementById('chDate').textContent=c.date.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'2-digit'});
  document.getElementById('chO').textContent='₹'+c.o.toFixed(2);
  document.getElementById('chH').textContent='₹'+c.h.toFixed(2);
  document.getElementById('chL').textContent='₹'+c.l.toFixed(2);
  document.getElementById('chC').textContent='₹'+c.c.toFixed(2);
  document.getElementById('chV').textContent=(c.v/1e6).toFixed(2)+'M';
  // tooltip
  document.getElementById('ttDate').textContent=c.date.toLocaleDateString('en-IN',{weekday:'short',day:'2-digit',month:'short',year:'numeric'});
  document.getElementById('ttO').textContent='₹'+c.o.toFixed(2);
  document.getElementById('ttH').textContent='₹'+c.h.toFixed(2);
  document.getElementById('ttL').textContent='₹'+c.l.toFixed(2);
  document.getElementById('ttC').textContent='₹'+c.c.toFixed(2);
  document.getElementById('ttV').textContent=(c.v/1e6).toFixed(3)+'M';
  tt.style.display='block';
  tt.style.left=(e.clientX+14)+'px';
  tt.style.top=(e.clientY-40)+'px';
});
cw.addEventListener('mouseleave',()=>{ tt.style.display='none'; });

// ─────────────────────────────────────────────────
//  TIMEFRAME
// ─────────────────────────────────────────────────
function setTF(tf){
  document.querySelectorAll('.tf-btn').forEach(b=>b.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('coLabel').textContent='PRICE · '+tf;
  // regenerate with different drift per tf
  const driftMap={'5m':-0.0001,'15m':-0.0002,'1H':-0.0003,'4H':-0.0004,'1D':-0.003,'1W':-0.008,'1M':-0.02};
  const nMap={'5m':200,'15m':120,'1H':100,'4H':80,'1D':120,'1W':60,'1M':40};
  CANDLES=genCandles(nMap[tf]||120,510,18,driftMap[tf]||-0.003);
  state.panX=Math.max(0,CANDLES.length-80);
  renderAll();
}

// ─────────────────────────────────────────────────
//  INDICATORS
// ─────────────────────────────────────────────────
function toggleInd(btn,key){
  state.inds[key]=!state.inds[key];
  btn.classList.toggle('active');
  renderAll();
}

// ─────────────────────────────────────────────────
//  SUB PANEL TOGGLE
// ─────────────────────────────────────────────────
function setPanel(panel, btn){
  state.activePanel=panel;
  document.querySelectorAll('.panel-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  const labels={macd:'MACD (12,26,9)',rsi:'RSI (14) · STOCHASTIC',vol:'VOLUME · OBV'};
  document.getElementById('subLabel1').textContent=labels[panel];
  renderAll();
}

// ─────────────────────────────────────────────────
//  FULLSCREEN
// ─────────────────────────────────────────────────
function openFullscreen(){
  const ov=document.getElementById('fs-overlay');
  ov.classList.add('open');
  state.fsZoom=state.zoom;
  setTimeout(()=>{ renderFS(); },50);
}
function closeFullscreen(){
  document.getElementById('fs-overlay').classList.remove('open');
}
document.addEventListener('keydown',e=>{ if(e.key==='Escape') closeFullscreen(); });
document.getElementById('fsChartWrap').addEventListener('wheel',e=>{
  e.preventDefault();
  const dir=e.deltaY<0?1:-1;
  state.fsZoom=Math.max(0.3,Math.min(8,state.fsZoom+dir*0.12));
  renderFS();
},{passive:false});

// ─────────────────────────────────────────────────
//  OPEN IN NEW TAB
// ─────────────────────────────────────────────────
function openNewTab(){
  // Serialize current HTML as blob and open
  const html=document.documentElement.outerHTML;
  const blob=new Blob([html],{type:'text/html'});
  const url=URL.createObjectURL(blob);
  window.open(url,'_blank');
  setTimeout(()=>URL.revokeObjectURL(url),5000);
}

// ─────────────────────────────────────────────────
//  RESIZE HANDLE
// ─────────────────────────────────────────────────
let resizing=false, resizeY=0;
const rh=document.getElementById('resizeH');
const sp1=document.getElementById('subPanel1');
const sp2=document.getElementById('subPanel2');
rh.addEventListener('mousedown',e=>{ resizing=true; resizeY=e.clientY; e.preventDefault(); });
window.addEventListener('mousemove',e=>{
  if(!resizing) return;
  const dy=e.clientY-resizeY; resizeY=e.clientY;
  const h1=sp1.clientHeight+dy, h2=sp2.clientHeight-dy;
  if(h1>30&&h2>30){ sp1.style.height=h1+'px'; sp2.style.height=h2+'px'; renderAll(); }
});
window.addEventListener('mouseup',()=>{ resizing=false; });

// ─────────────────────────────────────────────────
//  RESIZE OBSERVER
// ─────────────────────────────────────────────────
const ro=new ResizeObserver(()=>renderAll());
ro.observe(document.getElementById('chartWrap'));
ro.observe(document.getElementById('subPanel1'));
ro.observe(document.getElementById('subPanel2'));

// ─────────────────────────────────────────────────
//  INIT
// ─────────────────────────────────────────────────
window.addEventListener('load',()=>{ setTimeout(renderAll,100); });
window.addEventListener('resize',renderAll);
</script>

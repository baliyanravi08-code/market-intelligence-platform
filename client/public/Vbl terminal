<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VBL Terminal · Market Intelligence</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Orbitron:wght@400;600;700;900&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:        #060b14;
    --surface:   #0d1520;
    --surface2:  #111d2e;
    --surface3:  #162030;
    --border:    #1e3048;
    --border2:   #243a55;
    --accent:    #00e5ff;
    --accent2:   #00ff9c;
    --accent3:   #f7b731;
    --red:       #ff4560;
    --green:     #00e676;
    --green2:    #00ff9c;
    --text:      #c8dff0;
    --text2:     #6b8ca8;
    --text3:     #3d5a72;
    --bull:      #26a69a;
    --bear:      #ef5350;
    --glow:      0 0 20px rgba(0,229,255,0.15);
    --glow2:     0 0 30px rgba(0,230,118,0.12);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── TOP BAR ─────────────────────────────────────────── */
  .topbar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 16px;
    height: 46px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    position: relative;
    z-index: 100;
  }
  .topbar-logo {
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 2px;
    text-shadow: 0 0 12px var(--accent);
    white-space: nowrap;
  }
  .live-dot {
    width: 7px; height: 7px;
    background: var(--green);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--green);
    animation: pulse 1.4s infinite;
    flex-shrink: 0;
  }
  @keyframes pulse {
    0%,100% { opacity:1; transform:scale(1); }
    50% { opacity:.5; transform:scale(0.7); }
  }
  .sym-block { display:flex; align-items:baseline; gap:8px; margin-left:4px; }
  .sym-name  { font-family:'Orbitron',monospace; font-size:15px; font-weight:700; color:#fff; }
  .sym-price { font-family:'JetBrains Mono',monospace; font-size:20px; font-weight:700; color:#fff; letter-spacing:-0.5px; }
  .sym-change{ font-family:'JetBrains Mono',monospace; font-size:13px; }
  .sym-change.neg { color: var(--red); }
  .sym-change.pos { color: var(--green); }

  .ohlcv { display:flex; gap:18px; margin-left:auto; }
  .ohlcv-item { display:flex; flex-direction:column; align-items:flex-end; }
  .ohlcv-label { font-size:9px; color:var(--text3); text-transform:uppercase; letter-spacing:1px; }
  .ohlcv-val   { font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text); }

  .btn-group { display:flex; gap:4px; margin-left:12px; }
  .hdr-btn {
    display:flex; align-items:center; gap:5px;
    padding: 5px 10px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 5px;
    color: var(--text2);
    font-size: 11px;
    cursor: pointer;
    transition: all .15s;
    font-family:'Space Grotesk',sans-serif;
    white-space:nowrap;
  }
  .hdr-btn:hover { background:var(--surface3); border-color:var(--border2); color:var(--accent); }
  .hdr-btn.active { background: rgba(0,229,255,.08); border-color:var(--accent); color:var(--accent); }
  .hdr-btn svg { width:13px; height:13px; }

  /* ── TOOLBAR ─────────────────────────────────────────── */
  .toolbar {
    display:flex; align-items:center; gap:8px;
    padding: 6px 16px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .tf-btn {
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 11px;
    font-weight:500;
    cursor: pointer;
    border: 1px solid transparent;
    color: var(--text2);
    background: transparent;
    font-family:'Space Grotesk',sans-serif;
    transition: all .12s;
  }
  .tf-btn:hover { color:var(--text); background:var(--surface2); }
  .tf-btn.active { background:var(--accent); color:#000; font-weight:700; }

  .sep { width:1px; height:20px; background:var(--border); margin:0 4px; }

  .ind-btn {
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 11px;
    cursor: pointer;
    border: 1px solid var(--border);
    color: var(--text2);
    background: var(--surface2);
    font-family:'Space Grotesk',sans-serif;
    transition: all .12s;
  }
  .ind-btn.active { border-color: currentColor; }
  .ind-ma5   { color:#e91e63; }
  .ind-ma9   { color:#ff9800; }
  .ind-ma21  { color:#2196f3; }
  .ind-ma50  { color:#4caf50; }
  .ind-ma200 { color:#9c27b0; }
  .ind-st    { color:#00bcd4; }
  .ind-vwap  { color:#ffeb3b; }
  .ind-bb    { color:#607d8b; }

  .zoom-group { display:flex; gap:2px; margin-left:auto; }
  .zoom-btn {
    width:26px; height:26px;
    display:flex; align-items:center; justify-content:center;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    color: var(--text2);
    font-size: 14px;
    transition: all .12s;
    user-select:none;
  }
  .zoom-btn:hover { background:var(--surface3); color:var(--accent); border-color:var(--border2); }
  .zoom-level {
    padding: 4px 8px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-family:'JetBrains Mono',monospace;
    font-size:11px; color:var(--text2);
    min-width:44px; text-align:center;
  }

  .fs-btn {
    width:26px; height:26px;
    display:flex; align-items:center; justify-content:center;
    background: rgba(0,229,255,.06);
    border: 1px solid rgba(0,229,255,.25);
    border-radius: 4px;
    cursor: pointer;
    color: var(--accent);
    transition: all .12s;
    margin-left:4px;
  }
  .fs-btn:hover { background:rgba(0,229,255,.14); box-shadow:var(--glow); }

  .newtab-btn {
    display:flex; align-items:center; gap:4px;
    padding: 4px 10px;
    background: rgba(0,230,118,.06);
    border: 1px solid rgba(0,230,118,.25);
    border-radius: 4px;
    cursor: pointer;
    color: var(--green2);
    font-size:11px; font-weight:600;
    font-family:'Space Grotesk',sans-serif;
    transition: all .12s;
    margin-left:4px;
  }
  .newtab-btn:hover { background:rgba(0,230,118,.12); box-shadow:var(--glow2); }

  /* ── MAIN LAYOUT ─────────────────────────────────────── */
  .main {
    flex:1; display:flex; overflow:hidden;
  }
  .chart-col {
    flex:1; display:flex; flex-direction:column;
    overflow:hidden; position:relative;
  }

  /* ── CHART AREA ──────────────────────────────────────── */
  .chart-wrap {
    flex:1; position:relative; overflow:hidden;
    background: var(--bg);
    cursor: crosshair;
  }
  canvas#mainChart {
    display:block; width:100%; height:100%;
    image-rendering: pixelated;
  }
  .chart-overlay {
    position:absolute; top:10px; left:12px;
    pointer-events:none;
    display:flex; flex-direction:column; gap:2px;
  }
  .co-label { font-size:10px; color:var(--text3); font-family:'JetBrains Mono',monospace; }

  /* crosshair coords */
  .crosshair-info {
    position:absolute; bottom:8px; left:12px;
    pointer-events:none;
    display:flex; gap:16px;
    font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--text3);
  }
  .crosshair-info span { color:var(--text2); }

  /* ── SUB PANELS (MACD / RSI / VOL) ──────────────────── */
  .sub-panels {
    display:flex; flex-direction:column;
    border-top: 1px solid var(--border);
  }
  .sub-panel {
    position:relative; overflow:hidden;
  }
  .sub-panel-label {
    position:absolute; top:4px; left:8px;
    font-size:9px; color:var(--text3);
    font-family:'JetBrains Mono',monospace;
    letter-spacing:.5px; z-index:2;
    pointer-events:none;
  }
  canvas.sub-canvas { display:block; width:100%; }

  /* panel resize handle */
  .resize-handle {
    height:3px; background:var(--border);
    cursor:ns-resize; transition:background .15s;
  }
  .resize-handle:hover { background:var(--accent); }

  /* ── RIGHT PANEL ─────────────────────────────────────── */
  .right-panel {
    width: 240px;
    flex-shrink: 0;
    background: var(--surface);
    border-left: 1px solid var(--border);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .right-panel::-webkit-scrollbar { width:4px; }
  .right-panel::-webkit-scrollbar-track { background:transparent; }
  .right-panel::-webkit-scrollbar-thumb { background:var(--border); border-radius:2px; }

  /* Signal Card */
  .signal-card {
    margin:12px;
    background: linear-gradient(135deg, rgba(0,230,118,.05) 0%, rgba(0,230,118,.02) 100%);
    border: 1px solid rgba(0,230,118,.2);
    border-radius: 10px;
    padding: 14px;
    position:relative; overflow:hidden;
  }
  .signal-card::before {
    content:'';
    position:absolute; top:0; left:0; right:0; height:2px;
    background: linear-gradient(90deg, transparent, var(--green2), transparent);
  }
  .signal-header { display:flex; align-items:center; gap:10px; margin-bottom:10px; }
  .signal-dial {
    width:50px; height:50px; position:relative; flex-shrink:0;
  }
  .signal-dial svg { width:100%; height:100%; }
  .dial-score {
    position:absolute; inset:0;
    display:flex; align-items:center; justify-content:center;
    font-family:'Orbitron',monospace; font-size:13px; font-weight:700; color:#fff;
  }
  .signal-label { }
  .signal-name  { font-family:'Orbitron',monospace; font-size:14px; font-weight:700; color:var(--green2); letter-spacing:1px; }
  .signal-sub   { font-size:10px; color:var(--text2); margin-top:1px; }

  .signal-grid {
    display:grid; grid-template-columns:1fr 1fr 1fr;
    gap:6px; margin-top:8px;
  }
  .sg-item { background:var(--surface2); border:1px solid var(--border); border-radius:6px; padding:7px 8px; }
  .sg-label { font-size:9px; color:var(--text3); text-transform:uppercase; letter-spacing:.8px; }
  .sg-val   { font-family:'JetBrains Mono',monospace; font-size:13px; font-weight:600; color:#fff; margin-top:2px; }
  .sg-val.green { color:var(--green2); }
  .sg-val.red   { color:var(--red); }
  .sg-val.gold  { color:var(--accent3); }

  /* Sections */
  .rpanel-section { padding:10px 12px; border-top:1px solid var(--border); }
  .rpanel-title {
    font-size:9px; font-weight:600; text-transform:uppercase;
    letter-spacing:1.5px; color:var(--text3); margin-bottom:8px;
  }
  .rpanel-row {
    display:flex; justify-content:space-between; align-items:center;
    padding:4px 0; border-bottom:1px solid rgba(30,48,72,.5);
  }
  .rpanel-row:last-child { border-bottom:none; }
  .rpanel-key   { color:var(--text2); font-size:11px; }
  .rpanel-val   { font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--text); }
  .tag {
    display:inline-block; padding:1px 7px; border-radius:3px;
    font-size:9px; font-weight:700; letter-spacing:.5px; text-transform:uppercase;
  }
  .tag-bear { background:rgba(255,69,96,.15); color:var(--red); border:1px solid rgba(255,69,96,.3); }
  .tag-bull { background:rgba(0,230,118,.12); color:var(--green2); border:1px solid rgba(0,230,118,.25); }
  .tag-weak { background:rgba(107,140,168,.12); color:var(--text2); border:1px solid rgba(107,140,168,.2); }
  .tag-below{ background:rgba(255,69,96,.12); color:var(--red); border:1px solid rgba(255,69,96,.25); }
  .tag-os   { background:rgba(0,229,255,.1); color:var(--accent); border:1px solid rgba(0,229,255,.25); font-size:9px; }
  .tag-ob   { background:rgba(247,183,49,.1); color:var(--accent3); border:1px solid rgba(247,183,49,.25); font-size:9px; }
  .tag-bearish { background:rgba(255,69,96,.1); color:var(--red); border:1px solid rgba(255,69,96,.2); }

  /* Rr bar */
  .rr-bar {
    height:4px; border-radius:2px; overflow:hidden;
    background:var(--surface2); border:1px solid var(--border);
    margin-top:6px;
  }
  .rr-bar-fill {
    height:100%; border-radius:2px;
    background: linear-gradient(90deg, var(--red) 0%, var(--accent3) 33%, var(--green2) 100%);
    transition: width .6s ease;
  }

  /* ── FULLSCREEN OVERLAY ──────────────────────────────── */
  #fs-overlay {
    display:none;
    position:fixed; inset:0; z-index:9999;
    background: var(--bg);
    flex-direction:column;
  }
  #fs-overlay.open { display:flex; }
  #fs-overlay .chart-wrap { flex:1; }
  #fs-close {
    position:absolute; top:12px; right:16px; z-index:2;
    width:32px; height:32px;
    display:flex; align-items:center; justify-content:center;
    background: rgba(255,69,96,.1); border:1px solid rgba(255,69,96,.3);
    border-radius:6px; cursor:pointer; color:var(--red); font-size:18px;
    transition:all .15s;
  }
  #fs-close:hover { background:rgba(255,69,96,.2); }

  /* ── TOOLTIP ─────────────────────────────────────────── */
  #tooltip {
    position:fixed; z-index:1000;
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius:6px;
    padding:8px 12px;
    font-family:'JetBrains Mono',monospace;
    font-size:11px; color:var(--text);
    pointer-events:none; display:none;
    box-shadow: 0 8px 24px rgba(0,0,0,.5);
    min-width:140px;
  }
  #tooltip .tt-date { color:var(--text3); font-size:10px; margin-bottom:4px; }
  #tooltip .tt-row  { display:flex; justify-content:space-between; gap:16px; }
  #tooltip .tt-key  { color:var(--text2); }
  #tooltip .tt-val  { font-weight:600; }

  /* scrollbar in main */
  .right-panel { scrollbar-width:thin; }

  /* ── VOLUME ROW (below chart, above MACD) ────────────── */
  .panel-tabs { display:flex; gap:0; border-top:1px solid var(--border); }
  .panel-tab {
    padding:4px 12px; font-size:10px; color:var(--text3);
    cursor:pointer; border-right:1px solid var(--border);
    transition:all .12s; font-family:'JetBrains Mono',monospace;
    letter-spacing:.5px;
  }
  .panel-tab:hover { color:var(--text2); background:var(--surface2); }
  .panel-tab.active { color:var(--accent); background:rgba(0,229,255,.04); }

  /* ── ANIMATIONS ──────────────────────────────────────── */
  @keyframes fadeIn {
    from { opacity:0; transform:translateY(4px); }
    to   { opacity:1; transform:translateY(0); }
  }
  .signal-card, .rpanel-section { animation: fadeIn .4s ease both; }

  /* loading shimmer */
  .shimmer {
    background: linear-gradient(90deg, var(--surface2) 25%, var(--surface3) 50%, var(--surface2) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.2s infinite;
    border-radius:3px;
  }
  @keyframes shimmer {
    0%   { background-position:200% 0; }
    100% { background-position:-200% 0; }
  }

  /* watermark */
  .watermark {
    position:absolute; bottom:52px; right:16px;
    font-family:'Orbitron',monospace; font-size:11px;
    color:rgba(0,229,255,.04); letter-spacing:3px;
    pointer-events:none; user-select:none;
  }
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="topbar">
  <div class="topbar-logo">⬡ MI</div>
  <div class="live-dot"></div>
  <div class="sym-block">
    <span class="sym-name" id="symName">VBL</span>
    <span class="sym-price" id="symPrice">₹493.70</span>
    <span class="sym-change neg" id="symChange">▼ -3.21 (-0.65%)</span>
  </div>
  <div class="ohlcv">
    <div class="ohlcv-item"><div class="ohlcv-label">Open</div><div class="ohlcv-val" id="oOpen">₹496.91</div></div>
    <div class="ohlcv-item"><div class="ohlcv-label">High</div><div class="ohlcv-val" id="oHigh" style="color:var(--green)">₹502.29</div></div>
    <div class="ohlcv-item"><div class="ohlcv-label">Low</div><div class="ohlcv-val" id="oLow" style="color:var(--red)">₹484.41</div></div>
    <div class="ohlcv-item"><div class="ohlcv-label">Volume</div><div class="ohlcv-val">1.84M</div></div>
    <div class="ohlcv-item"><div class="ohlcv-label">52W H</div><div class="ohlcv-val">₹629.70</div></div>
    <div class="ohlcv-item"><div class="ohlcv-label">52W L</div><div class="ohlcv-val">₹383.90</div></div>
  </div>
</div>

<!-- TOOLBAR -->
<div class="toolbar">
  <button class="tf-btn" onclick="setTF('5m')">5m</button>
  <button class="tf-btn" onclick="setTF('15m')">15m</button>
  <button class="tf-btn" onclick="setTF('1H')">1H</button>
  <button class="tf-btn" onclick="setTF('4H')">4H</button>
  <button class="tf-btn active" id="tf-1D" onclick="setTF('1D')">1D</button>
  <button class="tf-btn" onclick="setTF('1W')">1W</button>
  <button class="tf-btn" onclick="setTF('1M')">1M</button>
  <div class="sep"></div>
  <button class="ind-btn ind-ma5  active" onclick="toggleInd(this,'ma5')">MA5</button>
  <button class="ind-btn ind-ma9  active" onclick="toggleInd(this,'ma9')">MA9</button>
  <button class="ind-btn ind-ma21 active" onclick="toggleInd(this,'ma21')">MA21</button>
  <button class="ind-btn ind-ma50 active" onclick="toggleInd(this,'ma50')">MA50</button>
  <button class="ind-btn ind-ma200 active" onclick="toggleInd(this,'ma200')">MA200</button>
  <button class="ind-btn ind-st  active" onclick="toggleInd(this,'st')">SuperTrend</button>
  <button class="ind-btn ind-vwap active" onclick="toggleInd(this,'vwap')">VWAP</button>
  <button class="ind-btn ind-bb  active" onclick="toggleInd(this,'bb')">BB</button>

  <div class="zoom-group" style="margin-left:auto">
    <button class="zoom-btn" onclick="zoomChart(-1)" title="Zoom Out">−</button>
    <div class="zoom-level" id="zoomLbl">100%</div>
    <button class="zoom-btn" onclick="zoomChart(+1)" title="Zoom In">+</button>
    <button class="zoom-btn" onclick="zoomReset()" title="Reset Zoom" style="font-size:10px;width:32px;">1:1</button>
  </div>
  <button class="fs-btn" onclick="openFullscreen()" title="Fullscreen">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14">
      <path d="M2 6V2h4M10 2h4v4M14 10v4h-4M6 14H2v-4"/>
    </svg>
  </button>
  <button class="newtab-btn" onclick="openNewTab()">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12">
      <rect x="1" y="3" width="10" height="10" rx="1.5"/>
      <path d="M6 1h9v9M10 6l5-5"/>
    </svg>
    New Tab
  </button>
</div>

<!-- MAIN -->
<div class="main">
  <!-- CHART COLUMN -->
  <div class="chart-col">
    <!-- PRICE CHART -->
    <div class="chart-wrap" id="chartWrap">
      <canvas id="mainChart"></canvas>
      <div class="chart-overlay">
        <div class="co-label" id="coLabel">PRICE · 1D</div>
      </div>
      <div class="watermark">MARKET INTELLIGENCE</div>
      <div class="crosshair-info" id="crosshairInfo">
        <span>Date: <span id="chDate">—</span></span>
        <span>O: <span id="chO">—</span></span>
        <span>H: <span id="chH">—</span></span>
        <span>L: <span id="chL">—</span></span>
        <span>C: <span id="chC">—</span></span>
        <span>Vol: <span id="chV">—</span></span>
      </div>
    </div>

    <div class="panel-tabs">
      <div class="panel-tab active" onclick="setPanel('macd',this)">MACD (12,26,9)</div>
      <div class="panel-tab" onclick="setPanel('rsi',this)">RSI (14) · STOCH</div>
      <div class="panel-tab" onclick="setPanel('vol',this)">VOLUME · OBV</div>
    </div>

    <!-- SUB PANEL -->
    <div class="sub-panels">
      <div class="sub-panel" id="subPanel1" style="height:90px">
        <div class="sub-panel-label" id="subLabel1">MACD (12,26,9)</div>
        <canvas class="sub-canvas" id="subChart1"></canvas>
      </div>
      <div class="resize-handle" id="resizeH"></div>
      <div class="sub-panel" id="subPanel2" style="height:80px">
        <div class="sub-panel-label" id="subLabel2">RSI (14) · STOCHASTIC</div>
        <canvas class="sub-canvas" id="subChart2"></canvas>
      </div>
    </div>
  </div>

  <!-- RIGHT PANEL -->
  <div class="right-panel" id="rightPanel">

    <!-- Signal Card -->
    <div class="signal-card">
      <div class="rpanel-title" style="margin-bottom:10px">LIVE SIGNAL · 1D</div>
      <div class="signal-header">
        <div class="signal-dial">
          <svg viewBox="0 0 50 50">
